# Moment — 环境变量模板（docker compose 读取）
# 使用方式：复制为仓库根目录 .env（已 gitignore），再 docker compose up …
#
# 统一开发流（各设备相同）：
#   1. docker compose up -d mysql redis
#   2. cd server && go run ./cmd/server
#   3. cd admin && npm run dev（或先 build 后用 compose 起全栈）
#
# 全栈容器：docker compose up -d（admin 需先有 admin/dist）
# 本机 Go 也可用环境变量覆盖 yaml，见 server/pkg/config/config.go bindEnvVars

# ========== 应用环境 ==========
APP_ENV=development
NODE_ENV=development

# ========== 数据库配置 (MySQL) ==========
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=moment
MYSQL_USER=moment
MYSQL_PASSWORD=moment_password
MYSQL_PORT=3306

# ========== Redis 配置 ==========
REDIS_PORT=6379

# ========== 后端服务配置 ==========
SERVER_PORT=8080

# ========== JWT 配置 ==========
# 生产环境请使用强密码，建议32位以上随机字符串
JWT_SECRET=your-secret-key-change-in-production

# ========== 管理端配置 ==========
ADMIN_PORT=80

# ========== 文件上传配置 ==========
# 最大文件大小（字节），默认 100MB
UPLOAD_MAX_SIZE=104857600

# ========== 日志配置 ==========
LOG_LEVEL=info
