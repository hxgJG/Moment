# Moment - 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# ========== 应用环境 ==========
APP_ENV=production
NODE_ENV=production

# ========== 数据库配置 (MySQL) ==========
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=moment
MYSQL_USER=moment
MYSQL_PASSWORD=moment_password
MYSQL_PORT=3306

# ========== Redis 配置 ==========
REDIS_PORT=6379

# ========== 后端服务配置 ==========
SERVER_PORT=8080

# ========== JWT 配置 ==========
# 生产环境请使用强密码，建议32位以上随机字符串
JWT_SECRET=your-secret-key-change-in-production

# ========== 管理端配置 ==========
ADMIN_PORT=80

# ========== 文件上传配置 ==========
# 最大文件大小（字节），默认 100MB
UPLOAD_MAX_SIZE=104857600

# ========== 日志配置 ==========
LOG_LEVEL=info
